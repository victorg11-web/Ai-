<!DOCTYPE html>
<html lang="da">
<head>
<meta charset="UTF-8">
<title>AI Chat Pro</title>

<style>
body {
  background: #020617;
  color: white;
  font-family: Arial;
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100vh;
}

.chat {
  width: 420px;
  background: #0f172a;
  border-radius: 12px;
  padding: 15px;
  box-shadow: 0 0 20px rgba(0,0,0,0.5);
}

.messages {
  height: 320px;
  overflow-y: auto;
  margin-bottom: 10px;
}

.msg {
  margin: 8px 0;
}

.user {
  text-align: right;
  color: #38bdf8;
}

.ai {
  text-align: left;
  color: #a78bfa;
}

.typing {
  font-size: 12px;
  opacity: 0.7;
}

input {
  width: 70%;
  padding: 10px;
  border-radius: 6px;
  border: none;
}

button {
  width: 25%;
  padding: 10px;
  background: #6366f1;
  border: none;
  border-radius: 6px;
  color: white;
  cursor: pointer;
}
</style>
</head>

<body>

<div class="chat">
  <div class="messages" id="messages"></div>

  <input id="input" placeholder="Skriv til AI..." />
  <button onclick="send()">Send</button>
</div>

<script>
const messages = document.getElementById("messages");

function add(text, cls) {
  const div = document.createElement("div");
  div.className = "msg " + cls;
  div.innerText = text;
  messages.appendChild(div);
  messages.scrollTop = messages.scrollHeight;
}

function send() {
  const input = document.getElementById("input");
  const text = input.value;
  if (!text) return;

  add(text, "user");
  input.value = "";

  const typing = document.createElement("div");
  typing.className = "typing";
  typing.innerText = "AI skriver...";
  messages.appendChild(typing);

  setTimeout(() => {
    typing.remove();

    // FAKE AI (kan skiftes ud med rigtig API)
    const reply = "🤖: " + text + " ... interessant!";
    add(reply, "ai");

  }, 800);
}
</script>

</body>
</html>
